// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id             String    @id @default(cuid())
  name           String
  phone          String
  email          String?
  treatment      String?
  procedure      String?
  message        String?
  city           String?
  age            String?
  pincode        String?
  consent        Boolean   @default(false)
  source         String?
  formName       String?
  status         String    @default("new")
  telecrmSynced  Boolean   @default(false)
  telecrmId      String?
  pageUrl        String?   // Add this field to store the URL where form was submitted
  referrerUrl    String?   // Add this field to store the referring URL
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("leads")
}